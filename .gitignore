*.vsix
node_modules/

# Build outputs of packages/vscode-extension/build-vendor.mjs.
# Source of truth for these lives in package.json (devDependencies),
# in the sibling `flatppl-grammars` repo (or the pinned remote tarball),
# and in packages/engine/ (the engine source). Re-run `npm run build:vendor`
# after dependency or engine changes.
packages/vscode-extension/lib/
packages/vscode-extension/grammars/
packages/vscode-extension/THIRD-PARTY-LICENSES.md
# Transpiled outputs of build-vendor.mjs's source-build step
# (extension.ts / src/visualPanel.ts → .js, loaded by VS Code's Node
# host). The .ts files are the source of truth.
packages/vscode-extension/extension.js
packages/vscode-extension/src/visualPanel.js

# Local symlinks created for the embed-test page (see
# packages/viewer/embed-test.html for the recipe). Source of truth
# is whatever the extension's lib/ currently builds — re-symlink
# after a `build:vendor` if needed.
packages/viewer/vendor/

# Build output of packages/web/build.mjs. Self-contained static-site
# directory deployed to GitHub Pages by the Pages workflow. Re-run
# `npm run build` (or `npm run watch`) under packages/web/ to refresh.
packages/web/dist/

# Coverage reports from `npm run test:coverage` (c8 — Node's built-in
# --experimental-test-coverage doesn't instrument type-stripped .ts,
# so the lcov.info ended up empty; c8 reads V8-coverage directly and
# produces real per-file data). Uploaded to Codecov by the CI workflow;
# not committed.
packages/*/coverage/
node_modules
