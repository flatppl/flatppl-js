{
  "name": "@flatppl/engine",
  "version": "0.1.0",
  "description": "Tokenizer, parser, analyzer, IR-lowering, and DAG-extraction utilities for the FlatPPL probabilistic language. JavaScript reference implementation.",
  "license": "MIT",
  "main": "./index.ts",
  "files": [
    "*.ts",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/flatppl/flatppl-js",
    "directory": "packages/engine"
  },
  "scripts": {
    "test": "node --test 'test/*.test.ts'",
    "test:coverage": "c8 --reporter=lcov --reporter=text-summary --include='*.ts' --exclude='*.d.ts' --exclude='test/**' --reports-dir=coverage node --test 'test/*.test.ts'",
    "typecheck": "tsc -p tsconfig.json",
    "typecheck:watch": "tsc -p tsconfig.json --watch"
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "fast-check": "^4.8.0"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@stdlib/random-base-bernoulli": "^0.2.1",
    "@stdlib/random-base-beta": "^0.2.1",
    "@stdlib/random-base-binomial": "^0.2.1",
    "@stdlib/random-base-cauchy": "^0.2.1",
    "@stdlib/random-base-exponential": "^0.2.1",
    "@stdlib/random-base-gamma": "^0.2.1",
    "@stdlib/random-base-lognormal": "^0.2.1",
    "@stdlib/random-base-normal": "^0.2.1",
    "@stdlib/random-base-poisson": "^0.2.1",
    "@stdlib/random-base-t": "^0.2.1",
    "@stdlib/random-base-uniform": "^0.2.1",
    "@stdlib/stats-base-dists-bernoulli-ctor": "^0.2.1",
    "@stdlib/stats-base-dists-beta-ctor": "^0.2.1",
    "@stdlib/stats-base-dists-binomial-ctor": "^0.2.1",
    "@stdlib/stats-base-dists-cauchy-ctor": "^0.2.1",
    "@stdlib/stats-base-dists-exponential-ctor": "^0.2.1",
    "@stdlib/stats-base-dists-gamma-ctor": "^0.2.1",
    "@stdlib/stats-base-dists-lognormal-ctor": "^0.2.1",
    "@stdlib/stats-base-dists-normal-ctor": "^0.2.2",
    "@stdlib/stats-base-dists-poisson-ctor": "^0.2.1",
    "@stdlib/stats-base-dists-t-ctor": "^0.2.1",
    "@stdlib/stats-base-dists-uniform-ctor": "^0.2.1"
  },
  "keywords": [
    "flatppl",
    "probabilistic",
    "parser",
    "ast"
  ]
}
