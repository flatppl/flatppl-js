{
  "// purpose":
    "Type-checks the engine's TypeScript modules. Node 24 strips types",
  "// rationale":
    "natively for the test path; esbuild bundles for the browser path.",
  "//":
    "tsc here is a lint-only step run via `npm run typecheck`.",

  "compilerOptions": {
    "target": "es2020",
    "module": "node16",
    "moduleResolution": "node16",
    "lib": ["es2020"],
    "types": ["node"],

    "noEmit": true,

    "strict": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,

    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "allowImportingTsExtensions": true
  },
  "include": ["**/*.ts"],
  "exclude": ["test/**/*", "node_modules/**/*"]
}
