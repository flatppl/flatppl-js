# Same semantics as bayesian_inference_1.flatppl, but uses measure restriction:
# build the joint model first, then restrict to observation.

# Prior distributions
theta1_dist = Normal(0, 1)
theta2_dist = Exponential(1)

# Prior variates
theta1 ~ theta1_dist
theta2 ~ theta2_dist

# Deterministic computation
c = 5                   % Scaling factor
f_a = par -> c * par    % Scale by c
f_b = fn(abs(_) * _)    % abs(arg1) * arg2
a = f_a(theta2)
b = f_b(theta1, theta2)

# IID observations from the forward model
obs ~ iid(Normal(mu = a, sigma = b), 10)

# Joint distribution over parameters and observations
joint_model = lawof(record(theta1 = theta1, theta2 = theta2, obs = obs))

# Observed data
observed_data = [1.2, 3.4, 5.1, 2.8, 4.0, 3.7, 5.5, 2.1, 4.3, 3.9]

# Structural disintegration
posterior = restrict(joint_model, record(obs = observed_data))

# Distribution of obs data for default_pars
pars_predictive = restrict(joint_model, default_pars)

# Preset points:
default_pars = record(theta1 = 0.5,  theta2 = 1.0)
alternative_pars = record(theta1 = -1.5, theta2 = fixed(0.8))

# Preset domain:
pars_domain = cartprod(theta1 = interval(-3, 3), theta2 = interval(0, 2))
