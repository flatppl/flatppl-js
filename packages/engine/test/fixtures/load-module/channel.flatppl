flatppl_compat = "0.1"

% Signal mean — an external module input (a loader pins it to a fixed value, spec §04: external ← fixed).
mu = external(reals)

% Known measurement resolution.
sigma = 0.7

% Observation measure (depends on the external input `mu`).
dist = Normal(mu, sigma)

% Concrete observation measure — needs no load-time substitution.
dist0 = Normal(0.0, sigma)
