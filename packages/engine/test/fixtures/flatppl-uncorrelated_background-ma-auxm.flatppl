# ===== Module imports =====

hepphys = standard_module("particle-physics", "0.1")

# ===== Nominal templates and uncertainties =====
sig = [12.0, 11.0]
bkg = [50.0, 52.0]
dbkg = [3.0, 7.0]

# ===== Observed data =====
obs_data = [51.0, 48.0]

# ===== Free parameters =====
mu = elementof(nonnegreals)
gamma = elementof(cartpow(posreals, 2))

# ===== Observation model =====
expected = mu .* sig .+ gamma .* bkg
obs_model = Poisson.(expected)
obs_kernel = functionof(obs_model, mu = mu, gamma = gamma)

# ===== Auxiliary constraint model =====
tau = (bkg ./ dbkg) .^ 2
aux_model = hepphys.ContinuedPoisson.(gamma .* tau)
aux_kernel = functionof(aux_model, gamma = gamma)

# ===== Likelihoods =====
L_obs = likelihoodof(obs_kernel, obs_data)
L_aux = likelihoodof(aux_kernel, tau)
L = joint_likelihood(L_obs, L_aux)
