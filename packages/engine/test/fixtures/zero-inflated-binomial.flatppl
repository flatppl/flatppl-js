%%%
Zero-inflated Binomial (ZIB) model:
y_i ~ psi * Binomial(K, p) + (1 - psi) * δ_0,
with Uniform(0, 1) priors on p and psi.
%%%

# Data
N = 10
K = 20
y_data = [7, 0, 5, 8, 0, 6, 4, 0, 9, 3]

# Priors
p ~ Beta(1, 1)        # Uniform(0, 1)
psi ~ Beta(1, 1)      # Uniform(0, 1)

# Per-observation mixture: Binomial(K, p) with weight psi, point mass at 0 with weight 1 - psi
zib_one = superpose(
    weighted(psi, Binomial(K, p)),
    weighted(1 - psi, Dirac(0))
)

y ~ iid(zib_one, N)

# Likelihood + posterior
prior = lawof(record(p = p, psi = psi))

forward_kernel = kernelof(
    record(y = y),
    p = p,
    psi = psi
)

L = likelihoodof(forward_kernel, record(y = y_data))
posterior = bayesupdate(L, prior)