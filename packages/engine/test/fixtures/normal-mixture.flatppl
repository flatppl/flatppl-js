%%%
# Two-component Normal mixture

p(y | theta, mu) = theta * Normal(y; mu[1], 1) + (1 - theta) * Normal(y; mu[2], 1).
Unknown mixture weight theta and component means mu[1], mu[2]; unit component
variance.
%%%


N = 20
y_data = [1.31, 2.25, -1.79, 2.30, 2.53,
 -1.49, 1.87, 1.55, -1.34, 2.18,
  1.28, -3.34, 0.56, 1.37, 0.43,
  -0.84, -0.54, 1.50, 1.71, 1.33]

theta ~ Beta(1, 1)
mu ~ iid(Normal(0, 10), 2)

mix = normalize(
    superpose(
        weighted(theta, Normal(mu[1], 1)), 
        weighted(1 - theta, Normal(mu[2], 1))
        )
    )

y ~ iid(mix, N)

prior = lawof(record(theta = theta, mu = mu))
forward_kernel = kernelof(record(y = y), theta = theta, mu = mu)
L = likelihoodof(forward_kernel, record(y = y_data))
posterior = bayesupdate(L, prior)
