{
  "// purpose":
    "Type-checks the viewer's JS modules via JSDoc + // @ts-check, without",
  "// rationale":
    "any code generation or rename to .ts. esbuild stays the build pipeline;",
  "//":
    "tsc here is a lint-only step run via `npm run typecheck`.",

  "compilerOptions": {
    "target": "es2020",
    "module": "es2020",
    "moduleResolution": "bundler",
    "lib": ["es2020", "dom"],

    "allowJs": true,
    "checkJs": true,
    "noEmit": true,

    "strict": true,
    "noImplicitAny": false,
    "strictNullChecks": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,

    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*.js", "src/**/*.ts", "src/**/*.d.ts"]
}
