{
  "// purpose":
    "Type-checks the viewer's TypeScript modules. esbuild stays the build",
  "// rationale":
    "pipeline (it strips types and bundles natively); tsc here is a",
  "//":
    "lint-only step run via `npm run typecheck`.",

  "compilerOptions": {
    "target": "es2020",
    "module": "es2020",
    "moduleResolution": "bundler",
    "lib": ["es2020", "dom"],

    "noEmit": true,

    "strict": true,
    "noImplicitAny": false,
    "strictNullChecks": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,

    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*.ts"]
}
