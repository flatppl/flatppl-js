.git/**
.gitignore
.vscodeignore
*.vsix

# Workspace-hoisted devDependencies. Everything that ships in the vsix
# is bundled into lib/ by build-vendor.mjs; node_modules itself doesn't ship.
node_modules/**
**/node_modules/**
package-lock.json
../../package-lock.json

# Build inputs — only build outputs (lib/* and grammars/*) ship in the vsix.
build-vendor.mjs

# --- non-runtime sources & build inputs (compiled outputs ship instead) ---
# TypeScript sources/config: compiled into extension.js, src/*.js, lib/math.cjs.
# No runtime require resolves to a .ts (the .js are the entrypoints).
**/*.ts
tsconfig.json
types/

# Build/CI helpers: imported only by build-vendor.mjs + tests, never at runtime.
build-lsp-source.cjs
build-stdlib-stub.cjs

# Test suites + grammar test harness: run via `node --test`/CI, not by VSCode.
test/
grammars/textmate/test/

# Release-asset install scripts — attached to the GitHub release, not shipped in the vsix.
install.sh
install.ps1
