# Test of various FlatPPL features

%%%
# Feature-test 1

Exercises a broad cross-section of FlatPPL features: independent
priors, deterministic transforms, IID observations, two ways of
building the forward kernel (direct reification and structural
disintegration), likelihood, posterior, weighted measures, and
preset / domain records.
%%%
flatppl_compat = "0.1"

# --- Prior distributions ---

% Standard normal prior on $\theta_1$: $\theta_1 \sim \mathcal{N}(0, 1)$.
theta1_dist = Normal(mu = 0, sigma = 1)
% Exponential prior with rate $\lambda = 1$: density $f(\theta_2) = e^{-\theta_2}$ for $\theta_2 \ge 0$.
theta2_dist = Exponential(rate = 1)

# Prior variates
theta1 ~ theta1_dist
theta2 = draw(theta2_dist)

c = 2.5                  % Scaling factor
_par = elementof(reals)

f_a = par -> c * par     % Scale by c
f_b = fn(abs(_) * _)     % abs(arg1) * arg2

# Deterministic transform
a = f_a(par = beta1)
b = f_b(theta1, theta2)

%%%
The forward model: ten IID Gaussian observations whose per-point
mean and scale come from the deterministic transforms `a` and `b`.
%%%
obs_dist = joint(obs = iid(Normal(mu = a, sigma = b), 10))

# prior and forward model
prior = lawof(record(theta1 = theta1, theta2 = theta2))
forward_kernel = functionof(obs_dist, theta1 = theta1, theta2 = theta2)

theta = draw(prior)

# Joint distribution over parameters and observations
joint_model = jointchain(prior, forward_kernel)

%%%typ
Structural disintegration of #emph[joint_model] into a forward
kernel + prior pair. Should be equivalent to the directly-built
`forward_kernel` and `prior` above (see the equivalence tests in
the engine suite).
%%%
forward_kernel2, prior2 = disintegrate(["obs"], joint_model)

rstate1 = rnginit([1,2,3,4])
rand_pars, rstate2 = rand(rstate1, prior)
expected_obs = forward_kernel(rand_pars)
rand_obs_data, _ = rand(rstate2, expected_obs)
rand_obs_values = rand_obs_data.obs

# Observed data
observed_data = [1.2, 3.4, 5.1, 2.8, 4.0, 3.7, 5.5, 2.1, 4.3, 3.9]
obs_data_dist = lawof(observed_data)
obs_data_dist2 = Dirac(observed_data)
observed_data2 ~ obs_data_dist

%%%md
Likelihood of the data under the structurally-disintegrated forward kernel:

$$L(\theta) = \prod_{i=1}^{n} p(x_i \mid \theta)$$

where $p(x_i \mid \theta) = \mathcal{N}(x_i;\, a(\theta),\, b(\theta))$ for each
observed datum $x_i$.
%%%
L = likelihoodof(forward_kernel2, record(obs = observed_data))

% Non-normalised posterior — combines `L` and `prior2`: $p(\theta \mid x) \propto L(\theta)\, \pi(\theta)$.
posterior = bayesupdate(L, prior2)

###
The bindings below exercise the engine's `weighted` form (valid
shapes plus three intentionally-invalid cases that the analyser
should reject — names starting with `invalid` are the cue).
###

theta3_dist = weighted(theta2, theta1_dist)
theta4_dist = weighted(draw(theta2_dist), theta1_dist)
theta4 = draw(weighted(draw(theta2_dist), theta1_dist))
theta5 ~ weighted(draw(theta2_dist)^2, theta1_dist)

invalid1_dist = weighted(theta2_dist, theta1_dist)
invalid2_dist = weighted(theta2, theta1)
invalid4_dist ~ weighted(exp(draw(theta2_dist), 2), theta1_dist)

stochastic_dist = Normal(theta1, theta2)

beta1 = 2 * theta2
beta1_dist = lawof(beta1)

foo = theta1 * theta2

xy_record = record(a = draw(Exponential(1)), b = draw(Exponential(1)))
xy_array = [draw(Exponential(1)), draw(Exponential(1))]
funnel_record = jointchain(a = Exponential(1), b = fn(Normal(1, _)))
funnel_array = jointchain(Exponential(1), fn(Normal(1, _)))


foo_dist = lawof(foo)

#w1 = weighted(0.5, theta1)
#w2 = weighted(0.5, theta1_dist)
#w3 = weighted(0.5, lawof(theta1))

#beta2 = pow(beta1, 2)

% Log-density of the observation model at the observed data.
lp_obs = logdensityof(obs_dist, record(obs = observed_data))
d_obs  = densityof(obs_dist, record(obs = observed_data))   % exp(lp_obs)

###
Preset points and plot domains. The next two lines demonstrate
the transport-safety rule: a single-line `%` terminates on a
semicolon as well as on a newline, so doc + binding can survive
newline-collapsing channels.
###
pars1 = record(theta1 = 1.3, theta2 = 0.8)             % Preset 1.
% Plot-domain for pars1-style records.; pars1_domain = cartprod(theta1 = interval(-4, 4), theta2 = interval(0.3, 5))

pars2 = record(theta1 = 0.5, theta2 = 2.0)             % Preset 2.

some_args1 = record(arg1 = 2.0, arg2 = 1.5)
some_args2 = record(arg1 = -1.0, arg2 = 0.5)

f_demo = fn(record(a = _, b = 2 * _))
y = f_demo(1, 2)
