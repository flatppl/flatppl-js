{
  "name": "@flatppl/web",
  "version": "0.1.0",
  "description": "Standalone web host for the FlatPPL viewer. Three-pane gallery shell (file tree, source view, viewer) targeting GitHub Pages and other static deployments. Embeds @flatppl/viewer with a fetch-based async resolver and a host adapter that bridges the viewer's revealSourceLine / setTitle / state-persistence callbacks.",
  "license": "MIT",
  "private": true,
  "files": [
    "src/",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/flatppl/flatppl-js",
    "directory": "packages/web"
  },
  "scripts": {
    "test": "node --test 'test/**/*.test.mjs'",
    "prebuild": "npm run typecheck",
    "build": "node ./build.mjs",
    "watch": "node ./build.mjs --watch",
    "serve": "node ./serve.mjs",
    "dev": "node ./dev.mjs",
    "typecheck": "tsc -p tsconfig.json",
    "typecheck:watch": "tsc -p tsconfig.json --watch"
  },
  "devDependencies": {
    "@codemirror/autocomplete": "^6.18.0",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.10.0",
    "@codemirror/lint": "^6.9.7",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.5.0",
    "@codemirror/view": "^6.43.2",
    "@dagrejs/dagre": "^3.0.0",
    "@flatppl/engine": "*",
    "@flatppl/viewer": "*",
    "cytoscape": "^3.30.4",
    "cytoscape-bubblesets": "^4.1.0",
    "cytoscape-dagre": "^4.0.0",
    "cytoscape-layers": "^3.1.0",
    "echarts": "^6.0.0",
    "esbuild": "^0.28.0",
    "vscode-oniguruma": "2.0.1",
    "vscode-textmate": "9.3.2"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "flatppl",
    "visualization",
    "gallery",
    "github-pages"
  ]
}
